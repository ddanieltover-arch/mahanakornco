# App
NEXT_PUBLIC_URL=https://mahanakornco.com
NEXT_PUBLIC_SITE_NAME="MAHANAKORN NAKO NAGARAJ CO., LTD"

# SMTP (Hostinger / business mail)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=sales@mahanakornco.com
SMTP_PASS=your_mailbox_password
SMTP_FROM_NAME=MAHANAKORN NAKO NAGARAJ CO., LTD
SMTP_FROM_EMAIL=sales@mahanakornco.com

# Where contact & product enquiry emails are delivered
CONTACT_EMAIL=sales@mahanakornco.com

# Send confirmation email to the customer (true by default)
SEND_AUTO_REPLY=true

# Admin dashboard (Supabase Auth + Postgres)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:password@aws-0-region.pooler.supabase.com:6543/postgres
ADMIN_EMAILS=sales@mahanakornco.com
